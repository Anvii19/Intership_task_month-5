1. Build Multi-threaded & Async Applications
✅ Async (Best for APIs)
import asyncio

async def fetch_data():
    await asyncio.sleep(1)
    return "Data fetched"

async def main():
    results = await asyncio.gather(fetch_data(), fetch_data())
    print(results)

asyncio.run(main())
✅ Multi-threading
from threading import Thread

def task():
    print("Running task")

t1 = Thread(target=task)
t2 = Thread(target=task)

t1.start()
t2.start()


