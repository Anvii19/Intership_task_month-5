Implement Concurrent / Parallel Processing
Purpose

Improve performance using multiple tasks simultaneously.

Example: Multithreading
File: src/services/thread_manager.py
import threading
import time

def worker(name):

    print(f"{name} Started")

    time.sleep(2)

    print(f"{name} Finished")

thread1 = threading.Thread(target=worker, args=("Task 1",))
thread2 = threading.Thread(target=worker, args=("Task 2",))

thread1.start()
thread2.start()

thread1.join()
thread2.join()

